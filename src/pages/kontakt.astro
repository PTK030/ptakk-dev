---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import handshakeEmoji from '../assets/emojis/handshake.png';
---

<Layout title="Kontakt | Kamil Ptak">
  <Navbar forceSolid={true} />

  <main class="contact-page">
    <div class="contact-page__container">
      <h1 class="contact-page__title">
        Przejdźmy do rzeczy. <img src={handshakeEmoji.src} alt="🤝" class="contact-page__title-emoji" style="width: 1.1em; height: 1.1em; vertical-align: -0.15em; margin-left: 0.3em; display: inline-block;" />
      </h1>
      <p class="contact-page__lead">
        Nie szukam projektów do portfolio, szukam problemów do rozwiązania. Ty określasz cel biznesowy, ja przejmuję technologię. Przejdźmy od razu do szczegółów.
      </p>

      <div class="contact-page__details">
        <a class="contact-page__mail" href="mailto:ptakk.dev@icloud.com">
          <span class="contact-page__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
              <rect x="3" y="5" width="18" height="14" rx="3"></rect>
              <path d="m4 7 8 6 8-6"></path>
            </svg>
          </span>
          <span class="contact-page__mail-copy">
            <span class="contact-page__label">Napisz bezpośrednio</span>
            <span class="contact-page__address">ptakk.dev@icloud.com</span>
          </span>
        </a>

        <nav class="contact-page__socials" aria-label="Media społecznościowe">
          <a class="contact-page__social" href="https://github.com/ptakk" target="_blank" rel="noreferrer" aria-label="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .7A11.5 11.5 0 0 0 8.4 23c.6.1.8-.3.8-.6v-2.2c-3.4.7-4.1-1.4-4.1-1.4-.5-1.4-1.4-1.8-1.4-1.8-1.1-.8.1-.8.1-.8 1.3.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.4 3.6 1 .1-.8.4-1.4.8-1.7-2.7-.3-5.6-1.4-5.6-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.6.1-3.1 0 0 1-.3 3.2 1.2a11 11 0 0 1 5.8 0c2.2-1.5 3.2-1.2 3.2-1.2.6 1.5.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.9 5.4-5.6 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A11.5 11.5 0 0 0 12 .7Z"></path>
            </svg>
          </a>
          <a class="contact-page__social" href="https://linkedin.com/in/kamilptak" target="_blank" rel="noreferrer" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M5.4 7.8H1.8V22h3.6V7.8ZM3.6 2A2.1 2.1 0 1 0 3.6 6.2 2.1 2.1 0 0 0 3.6 2Zm10 5.8H10V22h3.6v-7c0-1.9.4-3.7 2.7-3.7 2.2 0 2.2 2.1 2.2 3.8V22h3.6v-7.8c0-3.8-.8-6.8-5.3-6.8-2.1 0-3.6 1.2-4.2 2.3h-.1V7.8h1.1Z"></path>
            </svg>
          </a>
          <a class="contact-page__social" href="https://twitter.com/kamilptak" target="_blank" rel="noreferrer" aria-label="X">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.9 2H22l-6.8 7.8L23.2 22H17l-4.9-6.4L6.5 22H3.4l7.2-8.2L2.8 2h6.4l4.4 5.8L18.9 2Zm-1.1 17.9h1.7L8.3 4H6.5l11.3 15.9Z"></path>
            </svg>
          </a>
        </nav>
      </div>
    </div>
  </main>
</Layout>
